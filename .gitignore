# Terraform state
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Variable files (may contain sensitive data)
*.tfvars
!*.tfvars.example
terraform.tfvars.json

# Tenant config (.tfvars) carries no secrets - it IS the tenant inventory.
# Secrets are always generated and stored in Secret Manager, never here.
!tenants/**/*.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration
.terraformrc
terraform.rc

# Terraform working directories
.terraform/

# NOTE: .terraform.lock.hcl IS committed (provider version pinning).

# Plan output
*.tfplan
*.tfplan.json

# Local environment
.env
.env.local
.scaleway/
.scw/
scw-cli.ini

# Claude Code session/worktree metadata
.claude/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Backups
*.bak
*.backup
*.tmp

# SSH keys / credentials
*.pem
*.key
id_rsa*
known_hosts
credentials.json
service-account.json
scw-key-*.json
